SERVICE_NAME=xdom
ENVIRONMENT=prod
VERSION=0.1.0
COMMIT_SHA=unknown
BUILD_ID=local
LISTEN_ADDR=:8080
XPAY_SERVICE_NAME=xpay
XPAY_LISTEN_ADDR=:8081
ADMIN_TOKEN=replace-me
XPAY_ADMIN_TOKEN=replace-me
DB_PATH=/opt/xdom/data/xdom.db
LOG_LEVEL=info
TOKEN=replace-with-bk-token
OTLP_ENDPOINT=bk-report-1.woa.com:4318
OTLP_INSECURE=true
ENABLE_TRACES=true
ENABLE_METRICS=true
ENABLE_LOGS=true
OTLP_EXPORT_INTERVAL_SEC=5
OTLP_EXPORT_TIMEOUT_MS=5000
OTLP_TRACE_BATCH_TIMEOUT_MS=2000
OTLP_LOG_BATCH_TIMEOUT_MS=2000
NET_HOST_IP=127.0.0.1
PAYMENT_SERVICE_URL=http://127.0.0.1:8081
PAYMENT_REQUEST_TIMEOUT_MS=2000
PAYMENT_LATENCY_MS=150
XPAY_BASE_LATENCY_MS=150
ORDER_TIMEOUT_SEC=30
WORKER_INTERVAL_SEC=10
HEARTBEAT_LOG_INTERVAL_SEC=30
